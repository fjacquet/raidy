    "lz-string": "^1.5.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-error-boundary": "^4.1.2",
    "react-i18next": "^16.5.3",
    "recharts": "^3.6.0",
    "sonner": "^2.0.7",
    "zod": "^3.25.76",
