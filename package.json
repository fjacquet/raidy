    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "autoprefixer": "^10.4.23",
    "fast-check": "^4.5.3",
    "jsdom": "^27.4.0",
    "postcss": "^8.5.6",
    "snyk": "^1.1301.2",
